### Dart: Service Implementation

```dart
// src/flutter/{{ package_name }}/lib/src/{{ control_name_snake }}_service.dart
import 'package:flet/flet.dart';
import 'package:flutter/foundation.dart';

class {{ control_name }}Service extends FletService {
  {{ control_name }}Service({required super.control});

  @override
  void init() {
    super.init();
    control.addInvokeMethodListener(_onInvokeMethod);
  }

  Future<dynamic> _onInvokeMethod(String methodName, dynamic args) async {
    Map<String, dynamic> arguments = {};
    if (args != null && args is Map) {
      arguments = Map<String, dynamic>.from(args);
    }
    try {
      return switch (methodName) {
        "example_method" => _exampleMethod(arguments),
        _ => throw Exception("Unknown method: $methodName"),
      };
    } catch (error, stackTrace) {
      _handleError(methodName, error, stackTrace);
      return null;
    }
  }

  Future<void> _exampleMethod(Map<String, dynamic> args) async {
    final value = args["value"] as String?;
    // Call the actual Flutter SDK here
  }

  void _handleError(String method, Object error, StackTrace stackTrace) {
    debugPrint("{{ control_name }}Service ERROR in $method: $error");
    control.triggerEvent("error", {
      "method": method,
      "message": error.toString(),
      "stack_trace": stackTrace.toString(),
    });
  }
}
```

Key points:
- `addInvokeMethodListener` connects method calls from Python
- `switch` dispatches by method name string
- `_handleError` fires an `"error"` event back to Python
- Method name strings must match `_invoke_method` calls in Python

